# Auth secret for JWT signing — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string-please-32chars

# SQLite database file path (relative to project root)
DATABASE_PATH=./data/idm-ticket-master.db

# SMTP — when blank, emails are logged to the console only
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IDM Ticket Support <noreply@example.com>"

# Distribution lists for notifications (comma-separated)
EMAIL_IDM_DISTRIBUTION=
EMAIL_CONVERSION_DISTRIBUTION=lanze.avellanoza@accenture.com
